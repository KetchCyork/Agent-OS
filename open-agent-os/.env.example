# --- Models -------------------------------------------------------------
# OpenRouter: one key for Claude, Gemini, GLM, Kimi, and 300+ others, with
# automatic fallback. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: call Claude directly instead of via OpenRouter.
ANTHROPIC_API_KEY=

# Local models + embeddings (free, private). Install from https://ollama.com
OLLAMA_URL=http://localhost:11434

# --- Memory -------------------------------------------------------------
# Absolute path to your Obsidian vault. A starter layout is in vault-template/.
VAULT_PATH=

# Optional opt-in sources for memory/style learning.
ONEDRIVE_PROPOSALS_PATH=

# --- Connectors (opt-in) ------------------------------------------------
MOTION_API_KEY=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Cross-machine mesh -------------------------------------------------
# Shared secret required by remote mesh nodes when calling POST /command on HQ.
# Generate with: openssl rand -hex 32
GATEWAY_INBOUND_KEY=

# Secret required to register a new remote node with HQ (POST /remote/register).
REMOTE_NODE_REGISTRATION_KEY=

# URL of the HQ server as seen from remote nodes (used for callbacks/self-registration).
REMOTE_COMMAND_GATEWAY_URL=

# --- App ----------------------------------------------------------------
PORT=3737
